# ── Gorilla Markets · frontend env ────────────────────────────────────────
# Copy this file to `.env.local` and fill in. `.env.local` is gitignored — never
# commit a real key. With NONE of these set, the app falls back to the public
# devnet RPC (https://api.devnet.solana.com): rate-limited, but everything works.
#
# The RPC key is read SERVER-SIDE only (by app/api/rpc/route.ts) and is never
# shipped to the browser bundle. The browser talks to the same-origin /api/rpc proxy.

# A Helius devnet API key. The server builds https://devnet.helius-rpc.com/?api-key=$HELIUS_API_KEY
HELIUS_API_KEY=

# Or a full devnet RPC URL (takes precedence over HELIUS_API_KEY).
# DEVNET_RPC_URL=

# ── Future "mainnet simulation" mode (a seam, not wired) ─────────────────────
# A mainnet-fork RPC endpoint. Only needed if NEXT_PUBLIC_DATA_MODE=mainnet-sim.
# MAINNET_SIM_RPC_URL=

# Data-source mode, visible to the client. "devnet" (default) or "mainnet-sim".
# NEXT_PUBLIC_DATA_MODE=devnet

# ── Captured odds (MongoDB) ──────────────────────────────────────────────────
# The recorded TxLINE capture — `fixtures` + the `odds_updates` time series — that the
# /agent page replays. Read SERVER-SIDE ONLY, inside app/api/data/* (Node runtime).
#
# NEVER prefix these with NEXT_PUBLIC_: that inlines the value into the browser bundle and
# would publish the database credentials to every visitor.
#
# Required in the DEPLOYMENT environment too (Vercel → Settings → Environment Variables),
# or the deployed /agent page has no odds to show. Unset, /api/data/* returns an honest 503
# and the page renders an explicit "could not be read" state — never invented numbers.
MONGODB_URI=

# Database name. Defaults to "gorilla" when unset.
# MONGODB_DB=gorilla
