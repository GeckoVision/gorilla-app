[10.07684, "o", "\r\n"]
[10.87915, "o", "\u001b[32m18 passed.\u001b[0m  \u001b[2mThe proof is in the names:\u001b[0m\r\n"]
[11.882959, "o", "  \u001b[2mgate_two_hop_return_data_survives…  a result survives market→engine→feed\u001b[0m\r\n"]
[12.686032, "o", "  \u001b[2mpredicate_false_settles_no…         it settles NO honestly, not only YES\u001b[0m\r\n"]
[13.489335, "o", "  \u001b[2msettle_rejects_{fixture,stat,period}_mismatch  can't settle a different fact\u001b[0m\r\n"]
[14.292261, "o", "  \u001b[2mtampered_proof_reverts_settle       a faked proof pays nobody\u001b[0m\r\n"]
[15.095407, "o", "  \u001b[1minsurance_…\u001b[0m\u001b[2m  a DIFFERENT product on the SAME engine\u001b[0m\r\n"]
[15.898457, "o", "  \u001b[1minsurance_tampered_proof_reverts_and_leaves_funds_untouched\u001b[0m\r\n"]
[17.301985, "o", "\r\n"]
[18.104954, "o", "\u001b[2mA program that is not the market calls the engine, settles by proof,\u001b[0m\r\n"]
[18.906733, "o", "\u001b[2mand reverts on a tampered proof. Reuse you can verify — in one test run.\u001b[0m\r\n"]
[20.108851, "o", "\r\n"]
[20.910659, "o", "\u001b[1m\u001b[35mGORILLA\u001b[0m  \u001b[2msettled by proof — for our app, and anyone who builds on it\u001b[0m\r\n"]
